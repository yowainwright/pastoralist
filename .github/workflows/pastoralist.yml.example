# Copy the relevant sections to your own workflow files

# =============================================================================
# EXAMPLE 1: PR Check
# Validates overrides on every pull request — no write access needed
# =============================================================================
# name: Pastoralist Check
# on:
#   pull_request:
#     branches: [main, master]
#
# permissions:
#   contents: read
#
# jobs:
#   check-overrides:
#     runs-on: ubuntu-latest
#     steps:
#       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
#         with:
#           persist-credentials: false
#       - uses: yowainwright/pastoralist@v1
#         with:
#           mode: check
#           fail-on-security: true

# =============================================================================
# EXAMPLE 2: Weekly Maintenance PR
# Creates a PR with override updates every Monday
# =============================================================================
# name: Pastoralist Maintenance
# on:
#   schedule:
#     - cron: '0 9 * * 1'  # Monday at 9am UTC
#
# permissions:
#   contents: write
#   pull-requests: write
#
# jobs:
#   maintain-overrides:
#     runs-on: ubuntu-latest
#     steps:
#       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
#         with:
#           persist-credentials: false
#       - uses: yowainwright/pastoralist@v1
#         with:
#           mode: pr
#           pr-title: 'chore(deps): weekly override maintenance'
#           pr-labels: 'dependencies automated'

# =============================================================================
# EXAMPLE 3: Post-Install Hook
# Updates overrides after lock file changes land on main
# =============================================================================
# name: Pastoralist Update
# on:
#   push:
#     branches: [main]
#     paths:
#       - 'package.json'
#       - 'bun.lock'
#       - 'package-lock.json'
#       - 'yarn.lock'
#       - 'pnpm-lock.yaml'
#
# permissions:
#   contents: write
#   pull-requests: write
#
# jobs:
#   update-overrides:
#     runs-on: ubuntu-latest
#     steps:
#       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
#         with:
#           persist-credentials: false
#       - uses: yowainwright/pastoralist@v1
#         with:
#           mode: pr
#           pr-title: 'chore(deps): update override tracking'

# =============================================================================
# FULL EXAMPLE: Combined workflow for real-world use
# =============================================================================
name: Pastoralist

on:
  pull_request:
    branches: [main, master]
  push:
    branches: [main, master]
  schedule:
    - cron: "0 0 * * 0" # Weekly on Sunday

permissions:
  contents: read

jobs:
  # Run on PRs — check mode only, no file modifications
  pr-check:
    if: github.event_name == 'pull_request'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
        with:
          persist-credentials: false
      - name: Check overrides
        uses: yowainwright/pastoralist@v1
        with:
          mode: check
          fail-on-security: true
          fail-on-unused: false

  # Run on push to main — update and fail CI if changes were needed
  push-check:
    if: github.event_name == 'push'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
        with:
          persist-credentials: false
      - name: Update overrides
        uses: yowainwright/pastoralist@v1
        with:
          mode: update
      - name: Fail if overrides are out of date
        run: |
          if [ -n "$(git status --porcelain)" ]; then
            echo "::error::Pastoralist found stale overrides. Run 'pastoralist' locally and commit the result."
            git diff
            exit 1
          fi

  # Run on schedule — create PR if overrides need updating
  scheduled-maintenance:
    if: github.event_name == 'schedule'
    runs-on: ubuntu-latest
    permissions:
      contents: write
      pull-requests: write
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
        with:
          persist-credentials: false
      - name: Maintain overrides
        id: pastoralist
        uses: yowainwright/pastoralist@v1
        with:
          mode: pr
          pr-title: "chore(deps): scheduled override maintenance"
          pr-labels: "dependencies automated security"
      - name: Summary
        if: steps.pastoralist.outputs.pr-url != ''
        run: echo "Created PR — ${{ steps.pastoralist.outputs.pr-url }}"
