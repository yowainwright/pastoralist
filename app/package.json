{
  "name": "pastoralist-docs",
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run build:client && bun run build:static",
    "build:client": "bun run generate:llms && tsc && vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist-server",
    "build:static": "bun run build:ssr && bun run prerender",
    "generate:llms": "bun ../scripts/generate-llms-docs.ts",
    "prerender": "bun scripts/prerender.ts",
    "preview": "vite preview",
    "serve": "vite preview --port 5174",
    "test:unit": "bun test tests/unit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.3.0",
    "@mdx-js/mdx": "^3.1.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@shikijs/rehype": "^4.3.1",
    "@shikijs/transformers": "^4.3.1",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-router": "^1.170.18",
    "@vitejs/plugin-react": "^6.0.4",
    "@xstate/react": "^6.1.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.21.2",
    "framer-motion": "^12.42.2",
    "fuse.js": "^7.5.0",
    "github-slugger": "^2.0.0",
    "lucide-react": "^1.26.0",
    "mermaid": "^11.16.0",
    "pino": "^10.3.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-intersection-observer": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.7.0",
    "shaders": "^2.5.124",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unist-util-visit": "^5.1.0",
    "xstate": "^5.32.5"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/start": "^1.120.20",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "daisyui": "^5.7.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  },
  "peerDependencies": {},
  "optionalDependencies": {}
}
